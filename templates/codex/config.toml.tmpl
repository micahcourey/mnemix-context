# ─────────────────────────────────────────────────────────────────────────────
# Codex Configuration — {{project.name}}
# Generated by Mnemix Context — update toolkit.config.yaml and re-run generate.sh
# ─────────────────────────────────────────────────────────────────────────────
# Codex reads AGENTS.md automatically from the project root via the AGENTS.md
# symlink (created by setup-links.sh → points to .ai/AGENTS.md).
# No explicit instructions file is needed in most cases.
# ─────────────────────────────────────────────────────────────────────────────

# Default approval policy for tool use
# Options: "on-request" | "never" | "untrusted"
approval_policy = "on-request"

# Sandbox mode for file system access
# Options: "read-only" | "workspace-write" | "danger-full-access"
sandbox_mode = "workspace-write"

# ─── Agent role configs (optional, for Codex multi-agent workflows) ───────────
# Each named role applies a ConfigProfile overlay when that agent is spawned.
# The sections below are commented out by default because Codex ConfigProfile
# uses additionalProperties: false — uncomment the agents you want to activate.
# Reference the generated role files in .ai/codex/agents/:
#
# [agents.engineer]
# description = "Full-stack development for {{project.name}}"
# config_file = "agents/engineer.toml"
# nickname_candidates = ["eng", "engineer"]
#
# [agents.reviewer]
# description = "Code review and quality assurance for {{project.name}}"
# config_file = "agents/reviewer.toml"
# nickname_candidates = ["review", "reviewer", "pr"]
#
# [agents.documentation]
# description = "Documentation and README generation for {{project.name}}"
# config_file = "agents/documentation.toml"
# nickname_candidates = ["docs", "documentation"]
#
# [agents.architect]
# description = "Architecture planning, decomposition, and markdown plan files"
# config_file = "agents/architect.toml"
# nickname_candidates = ["architect", "arch", "planner"]
#
# [agents.setup]
# description = "Configure or refresh Mnemix Context for this repository"
# config_file = "agents/setup.toml"
# nickname_candidates = ["setup", "bootstrap", "config"]
#
