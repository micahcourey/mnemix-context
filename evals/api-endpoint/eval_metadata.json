        {
          "id": "has-audit",
          "type": "deterministic",
          "check": "transcript_contains",
          "pattern": "auditUserAction",
          "description": "Endpoint includes audit middleware"
        }
      ]
    },
    {
      "id": 2,
      "name": "crud-with-isolation",
      "prompt": "Create a full CRUD API for a 'project_actions' resource with tenant_id-based data isolation. Include routes, controller, service, and types.",
      "expected_output": "Complete CRUD with data isolation filtering on tenant_id.",
      "files": [],
      "assertions": [
        {
          "id": "has-tenant-filter",
          "type": "deterministic",
          "check": "transcript_contains",
          "pattern": "tenant_id",
          "description": "Queries filter by tenant_id for data isolation"
