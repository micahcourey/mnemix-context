      "expected_output": "Route file with full middleware chain, controller, service, and types.",
      "files": [],
      "assertions": [
        {
          "id": "has-auth-middleware",
          "type": "deterministic",
          "check": "transcript_contains",
          "pattern": "verifyTokenRetrieveUser",
          "description": "Endpoint includes authentication middleware"
        },
        {
          "id": "has-permission-check",
          "type": "deterministic",
          "check": "transcript_contains",
          "pattern": "validateRequiredPrivilege",
          "description": "Endpoint includes authorization middleware"
